# === Minecraft Server Agent Config ===

# Server RCON Configuration
RCON_HOST=127.0.0.1
RCON_PORT=25575
RCON_PASSWORD=your_rcon_password

# Log Tailing Configuration
MC_LOG_PATH=/path/to/your/minecraft/logs/latest.log

# LLM Configuration
# Choose your model provider (openai, deepseek, gemini, qwen)
MODEL_PROVIDER=openai

# Ensure you set the corresponding API keys for your chosen provider
OPENAI_API_KEY=your_openai_api_key
DEEPSEEK_API_KEY=your_deepseek_api_key
GEMINI_API_KEY=your_gemini_api_key
QWEN_API_KEY=your_qwen_api_key
